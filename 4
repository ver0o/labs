// Функция для вычисления длины (модуля) вектора
// Принимает неизменяемую ссылку на срез чисел f64
// Возвращает длину вектора (число f64)
fn magnitude(vector: &[f64]) -> f64 {
    // Переменная для хранения суммы квадратов координат
    let mut sum_squares = 0.0;
    
    // Проходим по каждой координате вектора
    // &coord - распаковываем ссылку, получаем само значение
    for &coord in vector {
        // Прибавляем квадрат координаты к общей сумме
        sum_squares += coord * coord;
    }
    
    // Возвращаем квадратный корень из суммы квадратов
    // Это и есть длина вектора по формуле: √(x² + y² + z²)
    sum_squares.sqrt()
}

// Функция для нормализации вектора (превращения его в единичный)
// Принимает изменяемую ссылку на срез, чтобы модифицировать исходный массив
fn normalize(vector: &mut [f64]) {
    // Вычисляем текущую длину вектора
    let mag = magnitude(vector);
    
    // Проверяем, что вектор не нулевой (нельзя делить на 0)
    if mag != 0.0 {
        // Проходим по каждой координате вектора
        // coord - это изменяемая ссылка на элемент (&mut f64)
        for coord in vector {
            // Делим координату на длину вектора
            // *coord - разыменование для изменения значения
            *coord /= mag;
        }
    }
}

fn main() {
    // Тест 1: Вычисляем длину единичного вектора [0, 1, 0]
    // Ожидаемый результат: 1.0
    println!("Модуль единичного вектора: {}", 
             magnitude(&[0.0, 1.0, 0.0]));

    // Тест 2: Создаём вектор [1, 2, 9]
    let mut v = [1.0, 2.0, 9.0];
    
    // Выводим длину вектора до нормализации
    // {v:?} - форматирование для вывода массива
    println!("Модуль {v:?}: {}", magnitude(&v));
    
    // Нормализуем вектор (делаем его длину равной 1)
    // &mut v - передаём изменяемую ссылку
    normalize(&mut v);
    
    // Выводим длину вектора после нормализации
    // Должна быть примерно 1.0
    println!("Модуль {v:?} после нормализации: {}", magnitude(&v));
}
